# Privy app id (create an app at dashboard.privy.io)
VITE_PRIVY_APP_ID=

# Backend API base URL (backend/src/server.ts), e.g. http://localhost:3000
VITE_BACKEND_URL=

# Solana RPC endpoint, e.g. http://127.0.0.1:8899 (localnet) or a devnet RPC
VITE_RPC_URL=

# TxLINE base URL — fill from the live TxLINE docs (left blank on purpose)
VITE_TXLINE_BASE_URL=
