# ── Acertana backend env ─────────────────────────────────────────────
# Copy to .env for local runs; set the same vars in Railway for deploys.

# 64 hex chars (32 bytes) for AES-256-GCM pick encryption. Generate yourself:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Losing it means stored (unrevealed) picks can't be decrypted — keep it safe.
PICK_STORE_KEY=

# Solana RPC. Devnet: https://api.devnet.solana.com  Local: http://127.0.0.1:8899
RPC_URL=https://api.devnet.solana.com

# Fixture-authority keypair (registers fixtures, pays reveal fees).
# Locally: a path. On Railway: base64 of the keypair json instead:
#   base64 -i .keys/fixture-authority-devnet.json
# NEVER commit this key. (Unset both -> falls back to the published test key.)
FIXTURE_AUTHORITY_KEYPAIR=../.keys/fixture-authority-devnet.json
# FIXTURE_AUTHORITY_KEYPAIR_B64=

# Privy server auth — verifies that join/picks callers own the wallet.
# Get both at dashboard.privy.io -> your app -> Settings -> API keys
# (App ID is public, App Secret is shown once — store it somewhere safe).
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Local dev without Privy: comment the two above and uncomment:
# ALLOW_UNAUTHENTICATED=1

# TxLINE sports data (fixtures + live scores). Mint the token once:
#   TXLINE_WALLET=<funded devnet keypair path> npm run txline-subscribe
# (free World Cup tier; wallet only pays devnet tx fees)
TXLINE_API_TOKEN=
# Devnet API host (default). Mainnet: https://txline.txodds.com
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
# Optional: restrict fixture sync to one competition (World Cup id from TxLINE)
# TXLINE_COMPETITION_ID=

# Comma-separated browser origins allowed by CORS (the deployed app URL).
CORS_ORIGIN=http://localhost:5173

# Any long random string; enables POST /admin/results (manual result injection).
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_TOKEN=

# SQLite location. On Railway: a path on the mounted volume, e.g. /data/acertana.db
DB_PATH=acertana.db

# Local dev only: seed fixtures + fake score feed instead of TxLINE.
# TXLINE_STUB=1

# Optional tuning (defaults shown)
# PORT=8787
# REVEAL_INTERVAL_MS=60000
# FIXTURE_SYNC_INTERVAL_MS=21600000
